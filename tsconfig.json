{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES6",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "lib": [
      "DOM",
      "ES2020",
    ]
  },
  "include": [
    "src/**/*.ts"
  ]
}