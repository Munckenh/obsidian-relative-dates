{
	"name": "obsidian-relative-dates",
	"version": "1.4.0",
	"description": "Relative, color-coded dates for Obsidian",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json package.json package-lock.json && git commit -m \"chore: $npm_package_version\" && git tag $npm_package_version -m \"\"",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"plugin",
		"date",
		"relative"
	],
	"author": "Munckenh",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/language": "6.5.0",
		"@codemirror/state": "6.5.0",
		"@codemirror/view": "6.38.6",
		"esbuild": "^0.28.0",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.6.0",
		"obsidian": "^1.12.3",
		"obsidian-daily-notes-interface": "0.9.4",
		"typescript": "^5.8.0",
		"typescript-eslint": "^8.59.3"
	}
}
