{
	"name": "obsidian-relative-dates",
	"version": "1.4.0",
	"description": "Relative, color-coded dates for Obsidian",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json package.json package-lock.json && git commit -m \"chore: $npm_package_version\" && git tag $npm_package_version -m \"\"",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"plugin",
		"date",
		"relative"
	],
	"author": "Munckenh",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/language": "6.11.2",
		"@codemirror/state": "6.5.0",
		"@codemirror/view": "6.38.6",
		"@types/node": "latest",
		"@typescript-eslint/parser": "latest",
		"esbuild": "latest",
		"eslint": ">=9.0.0",
		"eslint-plugin-obsidianmd": "latest",
		"globals": "latest",
		"obsidian": "latest",
		"obsidian-daily-notes-interface": "latest",
		"tslib": "latest",
		"typescript": "5.4.5",
		"typescript-eslint": "latest"
	}
}
